# Repo policy: only the `presence` project lives here. Everything else in the
# AI_OS workspace is excluded by default — any NEW root-level file or folder
# will not be tracked unless it's explicitly listed below.

# Block every root-level file/folder by default…
/*

# …then opt in only the four things that belong in this repo:
!/.gitignore
!/README.md
!/site/
!/worker/

# Inside the included dirs, exclude transient state / caches / secrets.
.wrangler/
.dev.vars
.env
.env.*
node_modules/
.DS_Store
